{
  "manifest_version": 3,
  "name": "TimeLoop",
  "description": "Track website visits and sync time spent to TimeLoop.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TimeLoop"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "storage",
    "idle",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "https://localhost/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
